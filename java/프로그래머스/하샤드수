class Solution {
    public boolean solution(int x) {
        boolean answer = true;
        int total =0;
        String str = String.valueOf(x);
        String[] chars = str.split("");
        
        for(int i=0; i<chars.length; i++){
            total += Integer.parseInt(chars[i]);
        }
        if(x%total == 0){
            answer = true;
        } else{
            answer = false;
        }
        return answer;
    }
}