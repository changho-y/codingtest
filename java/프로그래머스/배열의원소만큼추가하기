class Solution {
    public int[] solution(int[] arr) {
        int totalLength = 0;
        for (int i = 0; i < arr.length; i++) {
            totalLength += arr[i];
        }
        
        int[] answer = new int[totalLength];
        
        int index = 0;
        
        for (int i = 0; i < arr.length; i++) {
            for (int j = 0; j < arr[i]; j++) {
                answer[index] = arr[i];
                index++; 
            }
        }
        
        return answer;
    }
}